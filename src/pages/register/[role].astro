---
import Layout from '../../layouts/Layout.astro';
import RegisterForm from '../../components/RegisterForm.svelte';

export function getStaticPaths() {
  return [
    {params: {role: 'student'}},
    {params: {role: 'academic'}},
    {params: {role: 'alumni'}},
    {params: {role: 'dept-rep'}},
    {params: {role: 'dept-head'}},
  ];
}

const { role } = Astro.params;

const formatRole = (r: string) => {
    switch(r) {
        case 'student': return 'Student';
        case 'academic': return 'Academic Mentor';
        case 'alumni': return 'Alumni / Industry Mentor';
        case 'dept-rep': return 'Department Representative';
        case 'dept-head': return 'Department Head';
        default: return 'User';
    }
};

const title = `Account Registration`;
---

<Layout title={title} headerType="simple" subtitle={title} loginUrl={`/login/${role}`}>
	<RegisterForm role={role} client:load />
</Layout>
