---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <div class="hero">
    <h1>Welcome to UniConnect</h1>
    <p class="hero-subtitle">Your Undergraduate Management Platform</p>

    <div class="modules-grid">
      <a href="/materials" class="module-card">
        <span class="module-icon">📚</span>
        <h3>Study Materials</h3>
        <p>Upload and access study materials shared by your peers.</p>
      </a>

      <a href="/events" class="module-card">
        <span class="module-icon">🎯</span>
        <h3>Event Participation</h3>
        <p>Submit and track your event participations.</p>
      </a>

      <a href="/dashboard" class="module-card">
        <span class="module-icon">🏆</span>
        <h3>Contribution Points</h3>
        <p>View your contribution points and activity history.</p>
      </a>

      <a href="/mentors" class="module-card">
        <span class="module-icon">🤝</span>
        <h3>Mentor Connection</h3>
        <p>Connect with academic and industry mentors.</p>
      </a>

      <a href="/feedback" class="module-card">
        <span class="module-icon">💬</span>
        <h3>Mentor Feedback</h3>
        <p>Submit feedback for completed mentoring sessions.</p>
      </a>

      <a href="/analytics" class="module-card">
        <span class="module-icon">📈</span>
        <h3>Engagement Analytics</h3>
        <p>Monitor student engagement, mentor participation, and activity trends.</p>
      </a>
      <a href="/recommendations" class="module-card">
        <span class="module-icon">🎯</span>
        <h3>Mentor Recommendations</h3>
        <p>View mentors recommended based on your interests and skills.</p>
      </a>
      <a href="/reports" class="module-card">
        <span class="module-icon">📊</span>
        <h3>System Reports</h3>
        <p>Generate and download reports on contributions, mentoring, and engagement.</p>
      </a>
    </div>
  </div>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 48px 0 32px;
  }

  .hero h1 {
    font-size: 2.4rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 8px;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 48px;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
    text-align: left;
  }

  .module-card {
    background: #ffffff;
    border: 1.5px solid #e8ecf1;
    border-radius: 14px;
    padding: 28px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .module-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: #4361ee;
  }

  .module-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 12px;
  }

  .module-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 8px;
  }

  .module-card p {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.5;
  }
</style>
